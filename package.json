{
  "type": "module",
  "dependencies": {
    "color-namer": "^1.4.0",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "ps-client": "^5.3.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.59.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/color-namer": "~1.3.3",
    "@types/express": "~5.0.6",
    "@types/morgan": "~1.9.10",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.4",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "start": "npm run build && node --env-file=.env dist/main.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "pre-commit": "npm run lint && npm run build && npm run test"
  }
}
